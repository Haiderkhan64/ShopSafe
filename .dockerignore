# =============================================================================
#  .dockerignore — ShopSafe
#  Keep the build context lean. Anything listed here is never sent to the
#  Docker daemon, which speeds up `docker build` and prevents secrets leaking.
# =============================================================================

# ── Secrets & local config (NEVER send to daemon) ──────────────────────────
.env
.env.*
!.env.example          # allow the example file through for documentation
*.pem
*.key
secrets/

# ── Version control ─────────────────────────────────────────────────────────
.git
.gitignore
.gitattributes

# ── Node / npm ───────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.yarn/
.pnp.*

# ── Next.js build output (rebuilt inside Docker) ─────────────────────────────
.next/
out/

# ── Local dev database (Nix / flake) ─────────────────────────────────────────
.devdb/

# ── Test & coverage ──────────────────────────────────────────────────────────
__tests__/
*.test.ts
*.test.tsx
*.spec.ts
*.spec.tsx
coverage/
.nyc_output/

# ── Editor & OS artifacts ────────────────────────────────────────────────────
.DS_Store
.vscode/
.idea/
*.swp
*.swo
Thumbs.db

# ── CI / tooling ─────────────────────────────────────────────────────────────
.github/
.husky/
.eslintcache
.prettiercache

# ── Documentation ────────────────────────────────────────────────────────────
*.md
!README.md             # keep the top-level README if you want it in the image
docs/

# ── Miscellaneous ────────────────────────────────────────────────────────────
Dockerfile*
docker-compose*.yml
.dockerignore
*.log
*.tgz